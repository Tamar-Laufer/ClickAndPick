# הגדרות שרת
PORT=5000
NODE_ENV=development

# MongoDB (Click & Pick) — the new data layer
# Local: mongodb://127.0.0.1:27017/click_and_pick
# Atlas: mongodb+srv://<user>:<pass>@<cluster>/click_and_pick
MONGODB_URI=mongodb://127.0.0.1:27017/click_and_pick

# הגדרות MySQL — legacy (להסרה לאחר השלמת המעבר ל-Mongo)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=net

# JWT
JWT_SECRET=replace_with_strong_random_secret
JWT_EXPIRES_IN=7d

# Frontend URL — used to build the CTA links inside notification emails
CLIENT_URL=http://localhost:5173

# Timezone for scheduled jobs (the return-reminder cron runs at 08:00 in this TZ)
CRON_TZ=Asia/Jerusalem

# Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Email (SMTP) — להתראות ורשימת המתנה
# עם Gmail: הפעילי "App Password" ב-Google Account ← Security
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="ביחד" <your-email@gmail.com>
